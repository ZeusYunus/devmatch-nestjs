### Variables
@baseUrl = http://localhost:3000
@token = YOUR_API_TOKEN
@contentType = application/json

###

# Health Check
GET {{baseUrl}}/
Accept: application/json

###

# Get
GET {{baseUrl}}/profiles
Accept: application/json

###

# Get with query
GET {{baseUrl}}/profiles?location=Durban
Accept: application/json

###

# Get with parameter
GET {{baseUrl}}/profiles/1
Accept: application/json

###

# Post profile
POST {{baseUrl}}/profiles
Content-Type: {{contentType}}

{
  "name": "Nizaam Yunus",
  "description": "This Javascript coder is a master of syntax, a weaver of the web, and a connoisseur of coffee. In the morning, I like to make a wheatgrass juice and set aside an hour to read up on the latest JS releases before starting my day. There's just something electric about a fresh npm install, you know? Want to contribute to a new universe together?"
}

###

# Put profile
PUT {{baseUrl}}/profiles/sd89jsdf
Content-Type: {{contentType}}

{
  "name": "Cole Y",
  "description": "This damn PUT sh script. This Javascript coder is a master of syntax, a weaver of the web, and a connoisseur of coffee. In the morning, I like to make a wheatgrass juice and set aside an hour to read up on the latest JS releases before starting my day. Theres just something electric about a fresh npm install, you know? Want to contribute to a new universe together?"
}

###

# Delete profile
DELETE  {{baseUrl}}/profiles/ijsd899sdf
Content-Type: {{contentType}}

#############################################################################################################################################
#############################################################################################################################################
#############################################################################################################################################
#############################################################################################################################################
#############################################################################################################################################




###

# Get all users
GET {{baseUrl}}/users
Authorization: Bearer {{token}}
Accept: application/json

###

# Get a specific user
GET {{baseUrl}}/users/123
Authorization: Bearer {{token}}

###

# Create a user
POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "name": "John Doe",
  "email": "john@example.com",
  "role": "admin"
}

###

# Update a user
PUT {{baseUrl}}/users/123
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "name": "John Smith",
  "email": "john.smith@example.com"
}

###

# Partially update a user
PATCH {{baseUrl}}/users/123
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "role": "editor"
}

###

# Delete a user
DELETE {{baseUrl}}/users/123
Authorization: Bearer {{token}}

###

# Login request
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "password123"
}

###

# Upload a file
POST {{baseUrl}}/files/upload
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=MyBoundary

--MyBoundary
Content-Disposition: form-data; name="file"; filename="document.pdf"
Content-Type: application/pdf

< ./document.pdf
--MyBoundary--