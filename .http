### Variables
@baseUrl = http://localhost:3000
@token = YOUR_API_TOKEN
@contentType = application/json

###

# Health Check
GET {{baseUrl}}/
Accept: application/json

###

# Get
GET {{baseUrl}}/profiles
Accept: application/json

###

# Get with query
GET {{baseUrl}}/profiles?location=Durban
Accept: application/json

###

# Get with parameter
GET {{baseUrl}}/profiles/45dca5ea-9012-4c5d-8b81-9642d983b38b
Accept: application/json

###

# Post profile
POST {{baseUrl}}/profiles
Content-Type: {{contentType}}

{
  "name": "Jer",
  "description": "Why don't you play COD anymore"
}

###

# Put profile
PUT {{baseUrl}}/profiles/e973ea35-7e19-4513-8a02-4a6d30efbf90
Content-Type: {{contentType}}

{
  "name": "Cole Y",
  "description": "This damn PUT sh script. This Javascript coder is a master of syntax, a weaver of the web, and a connoisseur of coffee. In the morning, I like to make a wheatgrass juice and set aside an hour to read up on the latest JS releases before starting my day. Theres just something electric about a fresh npm install, you know? Want to contribute to a new universe together?"
}

###

# Delete profile
DELETE  {{baseUrl}}/profiles/b063d182-ba95-4609-b7f9-28f5233617c2
Content-Type: {{contentType}}

# ######################################################################################################################
# ######################################################################################################################
# ######################################################################################################################

### Get All Profiles
GET {{baseUrl}}/profiles

###

### Create Profile
POST {{baseUrl}}/profiles
Content-Type: application/json

{
  "name": "John Doe",
  "description": "NestJS developer looking for meaningful connections."
}

###

### Save the returned UUID here
@profileId = 00000000-0000-0000-0000-000000000000

### Get One
GET {{baseUrl}}/profiles/{{profileId}}

###

### Update
PUT {{baseUrl}}/profiles/{{profileId}}
Content-Type: application/json

{
  "name": "John Doe",
  "description": "Senior NestJS developer who loves TypeScript and MySQL."
}

###

### Delete
DELETE {{baseUrl}}/profiles/{{profileId}}